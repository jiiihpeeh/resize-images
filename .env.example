# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# Admin Credentials
ADMIN_USER=admin
ADMIN_PASSWORD=admin

# Registration Security (Required for new user registration)
REGISTRATION_SECRET=your-secret-key

# Image Processing Configuration
MAX_WIDTH=4096
MAX_HEIGHT=4096
IMAGE_TIMEOUT=30s

# Allowed hosts for image URLs (comma-separated, empty = allow all)
# ALLOWED_HOSTS=example.com,images.example.com

# Quality Settings (1-100)
QUALITY_JPEG=80
QUALITY_PNG=80
QUALITY_WEBP=80
QUALITY_AVIF=60
QUALITY_JXL=75

# Constraints for computationally expensive formats
# AVIF/JXL max dimension (width or height)
AVIF_MAX_RESOLUTION=2048
JXL_MAX_RESOLUTION=1920

# AVIF/JXL max total pixels (width * height)
AVIF_MAX_PIXELS=2500000
JXL_MAX_PIXELS=2000000

# Enable/disable formats
ENABLE_AVIF=true
ENABLE_JXL=true

# Rate limiting
MAX_CONCURRENT=2
REQUESTS_PER_MIN=60
